# ──────────────────────────────────────────────
# CIXCI Platform — Backend Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Settings module — use settings_local for SQLite (no Docker), settings for Postgres+Redis
# DJANGO_SETTINGS_MODULE=config.settings_local  # ← uncomment for no-Docker dev
# DJANGO_SETTINGS_MODULE=config.settings        # ← for Postgres+Redis

# Database (PostgreSQL / Google Cloud SQL)
# For Google Cloud SQL, specify your Cloud SQL instance public/private IP as DB_HOST, or localhost if using Cloud SQL Auth Proxy
DATABASE_URL=postgres://cixci:cixci@localhost:5432/cixci
DB_NAME=cixci
DB_USER=cixci
DB_PASSWORD=cixci
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=14

# AWS S3 / Cloudflare R2
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=cixci-media
AWS_S3_REGION_NAME=us-east-1
# For Cloudflare R2, override endpoint:
# AWS_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# Google Cloud Storage (GCS)
USE_GCS=False
GS_BUCKET_NAME=cixci-media-bucket
GS_PROJECT_ID=my-gcp-project-id
# GS_CREDENTIALS=path/to/key.json  # ← Path to service account JSON key file (optional if using environment auth)

# Email (SendGrid)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@cixci.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
