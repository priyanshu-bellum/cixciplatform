# ─── Environment Details ──────────────────────────────────────────────────────
ENV_NAME=test

# ─── Port Mappings (Host) ─────────────────────────────────────────────────────
REDIS_PORT=6380
BACKEND_PORT=8001
FRONTEND_PORT=8081

# ─── Django Settings ──────────────────────────────────────────────────────────
SECRET_KEY=change-to-a-very-secure-random-string-for-test
ALLOWED_HOSTS=testnew.cixci.com,127.0.0.1,localhost
FRONTEND_URL=https://testnew.cixci.com

# ─── Cloud SQL Database Connection ────────────────────────────────────────────
# Replace with the Public IP of your cixci-db-instace Cloud SQL instance
DB_HOST=1.2.3.4
DB_PORT=5432
DB_NAME=cixci_test
DB_USER=cixci
DB_PASSWORD=your_cloud_sql_password_here

# ─── React Frontend Build Argument ────────────────────────────────────────────
VITE_API_URL=https://testnew.cixci.com/api/v1

# ─── Optional: Google Cloud Storage (Media) ───────────────────────────────────
USE_GCS=False
GS_BUCKET_NAME=your-cixci-test-media-bucket
