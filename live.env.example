# ─── Environment Details ──────────────────────────────────────────────────────
ENV_NAME=live

# ─── Port Mappings (Host) ─────────────────────────────────────────────────────
REDIS_PORT=6379
BACKEND_PORT=8002
FRONTEND_PORT=8082

# ─── Django Settings ──────────────────────────────────────────────────────────
SECRET_KEY=change-to-a-very-secure-random-string-for-live
ALLOWED_HOSTS=livenew.cixci.com,127.0.0.1,localhost
FRONTEND_URL=https://livenew.cixci.com

# ─── Cloud SQL Database Connection ────────────────────────────────────────────
# Replace with the Public IP of your cixci-db-instace Cloud SQL instance
DB_HOST=1.2.3.4
DB_PORT=5432
DB_NAME=cixci_live
DB_USER=cixci
DB_PASSWORD=your_cloud_sql_password_here

# ─── React Frontend Build Argument ────────────────────────────────────────────
VITE_API_URL=https://livenew.cixci.com/api/v1

# ─── Optional: Google Cloud Storage (Media) ───────────────────────────────────
USE_GCS=False
GS_BUCKET_NAME=your-cixci-live-media-bucket
